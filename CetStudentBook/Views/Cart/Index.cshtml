@model IEnumerable<CetStudentBook.Models.CartItem>

<h2>Alışveriş Sepetim</h2>

@if (!Model.Any())
{
    <div class="alert alert-warning">Sepetinizde henüz hiç ürün yok.</div>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Ürün Adı</th>
                <th>Adet</th>
                <th>Fiyat</th>
                <th>Toplam</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.Quantity</td>
                    <td>@item.Price ₺</td>
                    <td>@(item.Quantity* item.Price) ₺</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="text-right">
        <a asp-controller="Cart" asp-action="Checkout" class="btn btn-success btn-lg">Satın Al (Buy)</a>
    </div>
}